{
  "name": "@wangwang/onetalk-adapter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "build": "npm run build -w @wangwang/collector-protocol && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @wangwang/collector-protocol && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wangwang/collector-protocol": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
