# Dependencies
node_modules/

# Build outputs
dist/
apps/*/dist/
packages/*/dist/
.vite/
.vite-temp/
*.tsbuildinfo

# Local environment
.env
.env.*
!.env.example

# Logs and runtime output
*.log
logs/*
