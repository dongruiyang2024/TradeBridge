# TradeBridge / 旺旺内部平台环境变量模板
#
# 本地开发时复制为 .env.local：
#   cp .env.example .env.local
#
# Node 启动入口会自动读取项目根目录下的 .env.local 和 .env；
# 只有在当前 shell 里直接使用 curl 等命令时，才需要手动 source。
#
# 不要提交真实生产密钥。

# ---------------------------------------------------------------------------
# 内部 API 服务（apps/server）
# ---------------------------------------------------------------------------
WANGWANG_SERVER_HOST=127.0.0.1
WANGWANG_SERVER_PORT=5032

# 开发期采集端兜底 token。
# 生产路径应通过 /internal/v1/collector-devices 注册设备获取 token。
WANGWANG_DEVICE_TOKENS=change-me-device-token

# 可选：PostgreSQL 持久化。
# 如果不设置，apps/server 会使用内存存储，服务重启后数据会丢失。
# DATABASE_URL=postgres://wait9yan:Weite123@127.0.0.1:5432/tradebridge

# 可选：用于 AI 任务的 Redis/BullMQ 队列。
# 如果不设置，AI 任务会走本地同步 fallback。
# REDIS_URL=redis://127.0.0.1:6379/0
# WANGWANG_REDIS_URL=redis://127.0.0.1:6379/0
WANGWANG_AI_QUEUE_WAIT_FOR_COMPLETION=false

# ---------------------------------------------------------------------------
# Web 销售工作台（apps/web）
# ---------------------------------------------------------------------------
# Web 工作台使用账号登录，服务端会签发内部 session。
# 开发环境下 Vite 会把 /internal 代理到 http://127.0.0.1:5032，
# 因此 UI 里的 API 输入框可以留空。
WANGWANG_DEFAULT_ORG_ID=org_internal

# ---------------------------------------------------------------------------
# 桌面采集端（apps/collector-desktop）
# ---------------------------------------------------------------------------
WANGWANG_ORG_ID=org_internal
WANGWANG_SERVER_URL=http://127.0.0.1:5032
WANGWANG_SELLER_ACCOUNT_ID=seller-demo
WANGWANG_SELLER_DISPLAY_NAME='Demo Seller'
WANGWANG_COLLECTOR_DEVICE_ID=demo-device
WANGWANG_DEVICE_NAME='Demo Mac'

# 使用 POST /internal/v1/collector-devices 返回的 token；
# 本地开发也可以先使用 WANGWANG_DEVICE_TOKENS 里的兜底 token。
WANGWANG_COLLECTOR_TOKEN=change-me-device-token

# 采集端本地运行状态文件，请保持在 git 之外。
WANGWANG_COLLECTOR_STATE_PATH=logs/collector-state.json

# 当前 Electron MVP 状态面板使用的临时显示标记。
# 真实采集仍依赖本机 AliSupplier/OneTalk 登录态。
WANGWANG_COLLECTOR_HAS_CTOKEN=1
# WANGWANG_COLLECTOR_HAS_COOKIE2=1
# WANGWANG_COLLECTOR_HAS_TB_TOKEN=1
# WANGWANG_COLLECTOR_HAS_SGCOOKIE=1

# ---------------------------------------------------------------------------
# 旧版本机查看器 API（apps/api）
# ---------------------------------------------------------------------------
WANGWANG_HOST=127.0.0.1
WANGWANG_PORT=5031
WANGWANG_API_TOKEN=
LOG_LEVEL=info

# 可选：覆盖 AliWorkbench/AliSupplier 本机登录态探测路径。
# macOS/Linux 使用冒号分隔多个路径；Windows 使用分号分隔。
# WANGWANG_LOG_PATHS=/path/to/cef.log
# WANGWANG_COOKIE_DB_PATHS=/path/to/Cookies
# WANGWANG_CHROMIUM_SAFE_STORAGE_SERVICE=Chromium Safe Storage
WANGWANG_KEYCHAIN_TIMEOUT_MS=10000

# 仅用于调试。不要提交真实 Chromium safe-storage 密钥。
# WANGWANG_CHROMIUM_SAFE_STORAGE_PASSWORD=
