{
  "name": "@wangwang/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build -w @wangwang/env && tsx watch src/server.ts",
    "test": "npm run build -w @wangwang/env && npm run build -w @wangwang/onetalk-adapter && node --import tsx --test test/*.test.ts",
    "build": "npm run build -w @wangwang/env && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "npm run build -w @wangwang/env && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@wangwang/env": "0.1.0",
    "@wangwang/onetalk-adapter": "0.1.0",
    "@wangwang/shared": "0.1.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
