{
  "name": "@wangwang/chrome-extension",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "test": "npm run build -w @wangwang/onetalk-adapter && node --import tsx --test test/*.test.ts",
    "build": "npm run build:local",
    "build:local": "tsc -p tsconfig.json && vite build --mode development",
    "build:test": "tsc -p tsconfig.json && vite build --mode test",
    "build:prod": "npm run build:production",
    "build:production": "tsc -p tsconfig.json && vite build --mode production",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wangwang/collector-protocol": "^0.1.0",
    "@wangwang/onetalk-adapter": "0.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
