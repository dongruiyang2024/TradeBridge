{
  "manifest_version": 3,
  "name": "TradeBridge OneTalk Collector",
  "version": "0.1.3",
  "description": "Sync authorized OneTalk conversations to TradeBridge without uploading OneTalk credentials.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "alarms", "scripting"],
  "host_permissions": ["https://onetalk.alibaba.com/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://onetalk.alibaba.com/*"],
      "js": ["channels/alibaba-im/onetalk-page-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["channels/alibaba-im/onetalk-page-script.js"],
      "matches": ["https://onetalk.alibaba.com/*"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html"
}
