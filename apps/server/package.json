{
  "name": "@wangwang/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build -w @wangwang/env && tsx watch src/server.ts",
    "test": "npm run build -w @wangwang/env && npm run build -w @wangwang/database && node --import tsx --test test/*.test.ts",
    "build": "npm run build -w @wangwang/env && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "npm run build -w @wangwang/env && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@wangwang/collector-protocol": "^0.1.0",
    "@wangwang/database": "0.1.0",
    "@wangwang/env": "0.1.0",
    "bullmq": "^5.77.3",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
