{
  "name": "@wangwang/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "test": "npm run build -w @wangwang/database && node --import tsx --test test/*.test.ts",
