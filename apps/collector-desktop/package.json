{
  "name": "@wangwang/collector-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "electron": "npm run build -w @wangwang/env && npm run build && electron dist/electron-main.js",
    "test": "npm run build -w @wangwang/env && node --import tsx --test test/*.test.ts",
    "build": "npm run build -w @wangwang/env && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @wangwang/env && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wangwang/database": "0.1.0",
    "@wangwang/env": "0.1.0",
    "@wangwang/onetalk-adapter": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "electron": "^41.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
